# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the DEFAULT (prod-like) Spring profile.
#
# These are read by src/main/resources/application.yaml. They are NOT needed for
# local development: the `local` profile (the default active profile) hardcodes
# its datasource and JWT secret in application-local.yaml.
#
# Usage:
#   cp .env.example .env          # then edit .env with real values
#   export $(grep -v '^#' .env | xargs) && ./gradlew bootRun
#
# The real .env file is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Selects the prod-like profile (omit/blank to fall back to `local`).
SPRING_PROFILES_ACTIVE=default

# --- Database (PostgreSQL) ---
DB_URL=jdbc:postgresql://<host>:5432/cinema_booking
DB_USERNAME=cinema
DB_PASSWORD=change-me

# --- JWT ---
# HMAC signing key — MUST be at least 32 bytes (256 bits) for HS256.
JWT_SECRET=replace-with-a-secret-of-at-least-32-bytes
# Token lifetime in milliseconds (default 86400000 = 24h).
JWT_EXPIRATION_MS=86400000

# --- HTTP ---
SERVER_PORT=8080
